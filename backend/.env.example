MONGO_URL=mongodb://localhost:27017/devtracker

# ── JWT ───────────────────────────────────────────────────────
SECRET_KEY=change_this_to_a_secure_random_key_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── App ───────────────────────────────────────────────────────
APP_NAME=DevTracker

# ── Corporate SSO Settings ────────────────────────────────────
# AUTH_MODE options:
# - auto: (default) Backend dynamically detects environment (intranet vs. public/home dev)
# - local: Force local credential verification against MongoDB / users table
# - sso: Force proxying authentication to the corporate SSO endpoint
AUTH_MODE=auto
SSO_LOGIN_URL=https://ssodev.ril.com/loginSAP
